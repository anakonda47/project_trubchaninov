#Дана строка 'груши 45 991 63 100 12 морковь 13 47 26 0 16', отражающая продажи
#продукции по дням в кг. Преобразовать информацию из строки в словари, с
#использованием функции найти минимальные продажи по каждому виду
#продукции, результаты вывести на экран.

def minimum(i):
    a = min(i)
    return a

sales = {}
produkt = ''

text = "груши 45 991 63 100 12 морковь 13 47 26 0 16"
b = text.split()
for x in b:
    if x.isdigit():
        sales[produkt].append(int(x))
    else:
        produkt = x
        sales[produkt] = []
print(sales)

for produkt,values in sales.items():
    print(produkt,":",minimum(values))
