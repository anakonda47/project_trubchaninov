#Дан список игрушек.Некоторые игрушки из этого списка имеются в N детсикх садах.
#Определить,каких игрушек из этого списка нет ни в одном из детских садов и какие есть в каждом из них
a  = {"кукла","машина","мяч","конструктор","пазлы","робот","кубики"}
b  = {"кукла","машина","мяч"}
c  = {"машина","конструктор","робот"}
d  = {"кукла","мяч","робот","кубики","машина"}
print("нет ни в одном:",a - b - c - d)
print("есть в каждом:",b & c & d)
